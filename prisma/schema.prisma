// ===========================================
// Файл: prisma/schema.prisma
// Описание:
//   БЛОЧНАЯ АРХИТЕКТУРА v5 + КАБИНЕТЫ.
//   Иерархия контента: Course → Unit → Lesson → Section → Blocks.
//   Банк упражнений (10 типов) привязан к разделам.
//   Кабинеты: Classroom, Enrollment, Invitation, Homework, Progress, Schedule.
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ПОЛЬЗОВАТЕЛИ ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  role          UserRole  @default(STUDENT)
  language      String?
  bio           String?   @db.Text
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teacherClassrooms    Classroom[]          @relation("ClassroomTeacher")
  enrollments          ClassroomEnrollment[]
  sentInvitations      Invitation[]         @relation("InvitationSender")
  receivedInvitations  Invitation[]         @relation("InvitationReceiver")
  exerciseAnswers      ExerciseAnswer[]
  homeworkStudentLinks HomeworkStudent[]
  lessonProgress       LessonProgress[]
  accounts             Account[]
  logAttendance        LessonLogAttendance[]
  logGrades            LessonLogGrade[]
  studyAssignmentLinks StudyAssignmentStudent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  LINGUIST
  TEACHER
  STUDENT
}

// ==================== ИЕРАРХИЯ: КУРС > ЮНИТ > УРОК > РАЗДЕЛ ====================

model Course {
  id             String   @id @default(cuid())
  title          String
  language       String
  targetLanguage String
  level          String
  description    String?  @db.Text
  coverImageUrl  String?
  isPublished    Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  units      Unit[]
  classrooms Classroom[]
}

model Unit {
  id        String   @id @default(cuid())
  courseId   String
  title     String
  description String? @db.Text
  order     Int      @default(0)
  isPublished Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id             String   @id @default(cuid())
  unitId         String
  title          String
  description    String?  @db.Text
  order          Int      @default(0)
  estimatedHours Float    @default(3)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  unit            Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  sections        Section[]
  lessonPlan      LessonPlan?
  progress        LessonProgress[]
  homeworkLessons HomeworkLesson[]
  logTopics       LessonLogTopic[]

  @@index([unitId])
}

model Section {
  id        String   @id @default(cuid())
  lessonId  String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  blocks    ContentBlock[]
  exercises Exercise[]
  visibility       SectionVisibility[]
  studyAssignments StudyAssignment[]

  @@index([lessonId])
}

// ==================== БЛОКИ КОНТЕНТА ====================

model ContentBlock {
  id          String           @id @default(cuid())
  sectionId   String
  type        ContentBlockType
  order       Int              @default(0)
  contentJson Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  section     Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacherNote TeacherNote?

  @@index([sectionId])
}

enum ContentBlockType {
  TEXT
  IMAGE
  AUDIO
  YOUTUBE
  DIVIDER
  SPACER
  HTML_EMBED
  VOCAB_CARD
  DIALOGUE
}

// ==================== СЛОЙ УЧИТЕЛЯ ====================

model TeacherNote {
  id             String   @id @default(cuid())
  contentBlockId String   @unique
  noteHtml       String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contentBlock ContentBlock @relation(fields: [contentBlockId], references: [id], onDelete: Cascade)
}

model LessonPlan {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  objectives      String[]
  timing60        Json?
  timing45        Json?
  materialsNeeded String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ==================== БАНК УПРАЖНЕНИЙ ====================

model Exercise {
  id                  String       @id @default(cuid())
  sectionId           String
  exerciseType        ExerciseType
  order               Int          @default(0)
  title               String       @default("")
  instructionText     String       @db.Text
  difficulty          Int          @default(1)
  contentJson         Json
  gradingType         GradingType  @default(AUTO)
  correctAnswers      String[]
  referenceAnswer     String?      @db.Text
  gradingCriteria     String?      @db.Text
  teacherComment      String?      @db.Text
  isDefaultInWorkbook Boolean      @default(true)
  isPublished         Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  section           Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers           ExerciseAnswer[]
  homeworkExercises HomeworkExercise[]
  assignments       ExerciseAssignment[]

  @@index([sectionId])
  @@index([exerciseType])
}

enum ExerciseType {
  MATCHING
  MULTIPLE_CHOICE
  TONE_PLACEMENT
  WORD_ORDER
  FILL_BLANK
  TRANSLATION
  WRITE_PINYIN
  DICTATION
  DESCRIBE_IMAGE
  FREE_WRITING
}

enum GradingType {
  AUTO
  TEACHER
}

// ==================== ОТВЕТЫ УЧЕНИКОВ ====================

model ExerciseAnswer {
  id              String        @id @default(cuid())
  exerciseId      String
  studentId       String
  homeworkId      String?
  answersJson     Json
  score           Int?
  status          AnswerStatus  @default(PENDING)
  teacherComment  String?       @db.Text
  gradedBy        String?
  attemptNumber   Int           @default(1)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  exercise Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  student  User      @relation(fields: [studentId], references: [id])
  homework Homework? @relation(fields: [homeworkId], references: [id])

  @@index([exerciseId])
  @@index([studentId])
  @@index([homeworkId])
}

enum AnswerStatus {
  PENDING
  GRADED
  AUTO_GRADED
}

// ==================== CLASSROOM ====================

model Classroom {
  id          String   @id @default(cuid())
  name        String
  teacherId   String
  courseId     String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     User     @relation("ClassroomTeacher", fields: [teacherId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])
  enrollments ClassroomEnrollment[]
  homework    Homework[]
  schedule    ScheduleSlot[]
  progress    LessonProgress[]
  invitations Invitation[]
  lessonLogs  LessonLog[]
  sectionVisibility    SectionVisibility[]
  studyAssignments     StudyAssignment[]
  exerciseAssignments  ExerciseAssignment[]

  @@index([teacherId])
  @@index([courseId])
}

model ClassroomEnrollment {
  id          String           @id @default(cuid())
  classroomId String
  studentId   String
  status      EnrollmentStatus @default(ACTIVE)
  joinedAt    DateTime         @default(now())

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id])

  @@unique([classroomId, studentId])
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
}

// ==================== ПРИГЛАШЕНИЯ ====================

model Invitation {
  id          String           @id @default(cuid())
  senderId    String
  receiverId  String
  classroomId String
  type        InvitationType
  status      InvitationStatus @default(PENDING)
  message     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  sender    User      @relation("InvitationSender", fields: [senderId], references: [id])
  receiver  User      @relation("InvitationReceiver", fields: [receiverId], references: [id])
  classroom Classroom @relation(fields: [classroomId], references: [id])

  @@index([receiverId, status])
  @@index([classroomId])
}

enum InvitationType {
  TEACHER_INVITES
  STUDENT_REQUESTS
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ==================== ПРОГРЕСС ====================

model LessonProgress {
  id          String         @id @default(cuid())
  classroomId String
  lessonId    String
  studentId   String
  status      ProgressStatus @default(NOT_STARTED)
  updatedAt   DateTime       @updatedAt

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id])

  @@unique([classroomId, lessonId, studentId])
  @@index([classroomId])
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ==================== ДОМАШНИЕ ЗАДАНИЯ ====================

model Homework {
  id           String       @id @default(cuid())
  classroomId  String
  lessonLogId  String?
  title        String
  type         HomeworkType
  dueDate      DateTime?
  instructions String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  classroom   Classroom          @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  lessonLog   LessonLog?         @relation("HomeworkLessonLog", fields: [lessonLogId], references: [id])
  readLessons HomeworkLesson[]
  exercises   HomeworkExercise[]
  students    HomeworkStudent[]
  answers     ExerciseAnswer[]

  @@index([classroomId])
  @@index([lessonLogId])
}

enum HomeworkType {
  READ
  EXERCISE
  MIXED
}

model HomeworkLesson {
  id         String @id @default(cuid())
  homeworkId String
  lessonId   String

  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  lesson   Lesson   @relation(fields: [lessonId], references: [id])

  @@index([homeworkId])
}

model HomeworkExercise {
  id         String @id @default(cuid())
  homeworkId String
  exerciseId String

  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([homeworkId])
}

model HomeworkStudent {
  id         String               @id @default(cuid())
  homeworkId String
  studentId  String
  status     HomeworkStudentStatus @default(ASSIGNED)
  note       String?              @db.Text
  updatedAt  DateTime             @updatedAt

  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student  User     @relation(fields: [studentId], references: [id])

  @@unique([homeworkId, studentId])
}

enum HomeworkStudentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  HAS_QUESTIONS
  REVIEWED
}

// ==================== РАСПИСАНИЕ ====================

model ScheduleSlot {
  id          String   @id @default(cuid())
  classroomId String
  dayOfWeek   Int
  startTime   String
  endTime     String
  location    String?

  classroom  Classroom   @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  lessonLogs LessonLog[]

  @@index([classroomId])
}

// ==================== ЭЛЕКТРОННЫЙ ЖУРНАЛ ====================

// Запись о занятии
model LessonLog {
  id              String          @id @default(cuid())
  classroomId     String
  scheduleSlotId  String?
  date            DateTime
  startTime       String
  endTime         String
  location        String?
  status          LessonLogStatus @default(SCHEDULED)
  teacherNotes    String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  classroom        Classroom              @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  scheduleSlot     ScheduleSlot?          @relation(fields: [scheduleSlotId], references: [id], onDelete: SetNull)
  attendance       LessonLogAttendance[]
  topics           LessonLogTopic[]
  grades           LessonLogGrade[]
  homeworkAssigned Homework[]             @relation("HomeworkLessonLog")

  @@index([classroomId])
  @@index([date])
  @@index([scheduleSlotId])
}

enum LessonLogStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// Посещаемость
model LessonLogAttendance {
  id          String           @id @default(cuid())
  lessonLogId String
  studentId   String
  status      AttendanceStatus @default(PRESENT)
  note        String?

  lessonLog LessonLog @relation(fields: [lessonLogId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id])

  @@unique([lessonLogId, studentId])
  @@index([lessonLogId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

// Пройденные темы (привязка к учебнику)
model LessonLogTopic {
  id          String  @id @default(cuid())
  lessonLogId String
  lessonId    String
  sectionId   String?
  completed   Boolean @default(true)

  lessonLog   LessonLog @relation(fields: [lessonLogId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id])

  @@index([lessonLogId])
}

// Оценки
model LessonLogGrade {
  id          String    @id @default(cuid())
  lessonLogId String
  studentId   String
  exerciseId  String?
  type        GradeType @default(CLASS_WORK)
  grade       String                // A, B, C, D, F, N/A
  comment     String?
  createdAt   DateTime  @default(now())

  lessonLog LessonLog @relation(fields: [lessonLogId], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [studentId], references: [id])

  @@index([lessonLogId])
  @@index([studentId])
}

enum GradeType {
  CLASS_WORK
  HOMEWORK
  PARTICIPATION
  QUIZ
}

// ==================== ВИДИМОСТЬ СЕКЦИЙ ДЛЯ УЧЕНИКОВ ====================
// studentId = "_ALL_" означает открыто для всех

model SectionVisibility {
  id          String   @id @default(cuid())
  sectionId   String
  classroomId String
  studentId   String   @default("_ALL_")
  openedBy    String
  createdAt   DateTime @default(now())

  section   Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@unique([sectionId, classroomId, studentId])
  @@index([classroomId])
}

// ==================== НАЗНАЧЕНИЕ СЕКЦИЙ УЧЕБНИКА ====================

model StudyAssignment {
  id          String              @id @default(cuid())
  sectionId   String
  classroomId String
  assignedBy  String
  type        StudyAssignmentType @default(HOMEWORK)
  createdAt   DateTime            @default(now())

  section   Section                @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  classroom Classroom              @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  students  StudyAssignmentStudent[]

  @@index([classroomId])
  @@index([sectionId])
}

enum StudyAssignmentType {
  CLASS_WORK
  HOMEWORK
}

model StudyAssignmentStudent {
  id                String                @id @default(cuid())
  studyAssignmentId String
  studentId         String
  status            StudyAssignmentStatus @default(ASSIGNED)
  grade             String?
  comment           String?               @db.Text
  updatedAt         DateTime              @updatedAt

  studyAssignment StudyAssignment @relation(fields: [studyAssignmentId], references: [id], onDelete: Cascade)
  student         User            @relation(fields: [studentId], references: [id])

  @@unique([studyAssignmentId, studentId])
  @@index([studentId])
}

enum StudyAssignmentStatus {
  ASSIGNED
  COMPLETED
  HAS_QUESTION
}

// ==================== НАЗНАЧЕНИЕ УПРАЖНЕНИЙ ====================
// studentId = "_ALL_" означает назначено всем

model ExerciseAssignment {
  id          String   @id @default(cuid())
  exerciseId  String
  classroomId String
  studentId   String   @default("_ALL_")
  isFromBank  Boolean  @default(false)
  createdAt   DateTime @default(now())

  exercise  Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([classroomId])
  @@index([exerciseId])
}
