// ===========================================
// Файл: prisma/schema.prisma
// Путь:  linguamethod-admin/prisma/schema.prisma
//
// Описание:
//   БЛОЧНАЯ АРХИТЕКТУРА v4.
//   Свободные разделы + универсальные блоки-кирпичики.
//   Банк упражнений (10 типов) привязан к разделам.
//   Рабочая тетрадь = упражнения с isDefaultInWorkbook=true.
//   ContentBlock — одна таблица для 10 типов контента.
//   Exercise — одна таблица для 10 типов упражнений.
//   SPACER заменил TONE_BLOCK. Карточка слова — универсальная.
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ПОЛЬЗОВАТЕЛИ ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          UserRole  @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  LINGUIST
}

// ==================== ИЕРАРХИЯ: КУРС > МОДУЛЬ > УРОК > РАЗДЕЛ ====================

model Course {
  id             String   @id @default(cuid())
  title          String
  language       String
  targetLanguage String
  level          String
  description    String?  @db.Text
  coverImageUrl  String?
  isPublished    Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modules Module[]
}

model Module {
  id             String   @id @default(cuid())
  courseId        String
  title          String
  description    String?  @db.Text
  order          Int      @default(0)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id             String   @id @default(cuid())
  moduleId       String
  title          String
  description    String?  @db.Text
  order          Int      @default(0)
  estimatedHours Float    @default(3)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  module     Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sections   Section[]
  lessonPlan LessonPlan?

  @@index([moduleId])
}

// Раздел — СВОБОДНЫЙ. Любое название, любой порядок.
model Section {
  id        String   @id @default(cuid())
  lessonId  String
  title     String   // Свободное: "Новые слова", "О культуре", что угодно
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  blocks    ContentBlock[] // Блоки-кирпичики внутри раздела
  exercises Exercise[]     // Упражнения к разделу

  @@index([lessonId])
}

// ==================== БЛОКИ КОНТЕНТА (кирпичики) ====================

// Универсальный блок. Один тип таблицы для всего контента.
// Тип блока определяет структуру contentJson.
model ContentBlock {
  id          String           @id @default(cuid())
  sectionId   String
  type        ContentBlockType // Какой это блок (текст, картинка, карточка слова...)
  order       Int              @default(0) // Порядок в разделе (для перемещения)
  contentJson Json             // Содержимое — структура зависит от type
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  section     Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacherNote TeacherNote? // Методическая заметка (только для учителя)

  @@index([sectionId])
}

// 10 типов блоков контента
enum ContentBlockType {
  // --- Базовые ---
  TEXT           // Форматированный текст (Tiptap WYSIWYG)
  IMAGE          // Картинка с подписью
  AUDIO          // Аудио-файл с плеером
  YOUTUBE        // Видео с YouTube
  DIVIDER        // Разделитель (горизонтальная линия)
  SPACER         // Пустая строка — настраиваемый отступ (sm/md/lg)
  HTML_EMBED     // Кастомный HTML/iframe код

  // --- Специализированные для языков ---
  VOCAB_CARD     // Универсальная карточка слова (слово + перевод + транскрипция + аудио + картинка + пример)
  GRAMMAR_RULE   // Грамматическое правило (заголовок + формула MathLive + объяснение + примеры)
  DIALOGUE       // Диалог (участники + реплики + аудио)
}

// ==================== СЛОЙ УЧИТЕЛЯ ====================

// Методическая заметка — привязывается к ЛЮБОМУ блоку
model TeacherNote {
  id             String   @id @default(cuid())
  contentBlockId String   @unique
  noteHtml       String   @db.Text // Текст заметки
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contentBlock ContentBlock @relation(fields: [contentBlockId], references: [id], onDelete: Cascade)
}

// План урока
model LessonPlan {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  objectives      String[]
  timing60        Json?
  timing45        Json?
  materialsNeeded String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ==================== БАНК УПРАЖНЕНИЙ ====================
// Все упражнения хранятся в банке, привязаны к разделу (Section).
// Банк курса = все упражнения всех разделов всех уроков курса.
// Рабочая тетрадь = упражнения с isDefaultInWorkbook=true.
// В будущем: учитель сможет персонализировать набор для ученика.

model Exercise {
  id                  String       @id @default(cuid())
  sectionId           String                           // Привязка к разделу
  exerciseType        ExerciseType                     // Тип упражнения (11 типов)
  order               Int          @default(0)         // Порядок в разделе
  title               String       @default("")        // Короткое название для банка
  instructionText     String       @db.Text             // Задание для ученика
  difficulty          Int          @default(1)          // Сложность 1-5
  contentJson         Json                              // Содержимое — структура зависит от exerciseType
  gradingType         GradingType  @default(AUTO)       // AUTO = автопроверка, TEACHER = ручная
  correctAnswers      String[]                          // Эталонные ответы (для автопроверки)
  referenceAnswer     String?      @db.Text             // Образцовый ответ (для ручной проверки)
  gradingCriteria     String?      @db.Text             // Устарело — заменено на teacherComment
  teacherComment      String?      @db.Text             // Комментарий для учителя: почему этот ответ правильный
  isDefaultInWorkbook Boolean      @default(true)       // Входит в тетрадь по умолчанию
  isPublished         Boolean      @default(false)      // Опубликовано ли
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  section  Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers  ExerciseAnswer[]  // Ответы учеников (будущее)

  @@index([sectionId])
  @@index([exerciseType])
}

// 11 типов упражнений для MVP
enum ExerciseType {
  // === Автопроверка (4 типа) ===
  MATCHING              // Соединить пары (слово↔перевод, пиньинь↔иероглиф)
  MULTIPLE_CHOICE       // Выбрать правильный ответ из вариантов
  TONE_PLACEMENT        // Расставить тоны над пиньинь (китайский)
  WORD_ORDER            // Составить предложение из перемешанных слов

  // === Ручная проверка учителем (7 типов) ===
  FILL_BLANK            // Вписать слово в пропуск в предложении
  TRANSLATION           // Перевести с одного языка на другой (универсально)
  WRITE_PINYIN          // Написать пиньинь над иероглифами (китайский)
  DICTATION             // Диктант: слушай аудио → пиши
  DESCRIBE_IMAGE        // Опиши картинку
  FREE_WRITING          // Свободное письменное задание
}

enum GradingType {
  AUTO      // Автоматическая проверка (сравнение с эталоном)
  TEACHER   // Ручная проверка учителем
}

// ==================== ОТВЕТЫ УЧЕНИКОВ (будущее) ====================

model ExerciseAnswer {
  id              String        @id @default(cuid())
  exerciseId      String
  studentId       String?                              // ID ученика (будущее)
  answersJson     Json                                 // Ответ ученика
  score           Int?                                 // Балл
  status          AnswerStatus  @default(PENDING)      // Статус проверки
  teacherComment  String?       @db.Text               // Комментарий учителя
  gradedBy        String?                              // Кто проверил
  attemptNumber   Int           @default(1)            // Номер попытки
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

enum AnswerStatus {
  PENDING      // Ожидает проверки
  GRADED       // Проверено учителем
  AUTO_GRADED  // Проверено автоматически
}
