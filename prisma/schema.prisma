// ===========================================
// Файл: prisma/schema.prisma
// Путь:  linguamethod-admin/prisma/schema.prisma
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ПОЛЬЗОВАТЕЛИ АДМИНКИ ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          UserRole  @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  LINGUIST
}

// ==================== ИЕРАРХИЯ: КУРС > МОДУЛЬ > УРОК > РАЗДЕЛ ====================

model Course {
  id             String   @id @default(cuid())
  title          String
  language       String
  targetLanguage String
  level          String
  description    String?  @db.Text
  coverImageUrl  String?
  isPublished    Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modules Module[]
}

model Module {
  id             String   @id @default(cuid())
  courseId        String
  title          String
  description    String?  @db.Text
  order          Int      @default(0)
  wordCount      Int      @default(0)
  characterCount Int      @default(0)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id             String   @id @default(cuid())
  moduleId       String
  title          String
  description    String?  @db.Text
  order          Int      @default(0)
  estimatedHours Float    @default(3)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  module     Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sections   Section[]
  lessonPlan LessonPlan?

  @@index([moduleId])
}

model Section {
  id        String      @id @default(cuid())
  lessonId  String
  type      SectionType
  title     String
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  lesson          Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  vocabularyCards VocabularyCard[]
  toneBlocks      ToneBlock[]
  grammarBlocks   GrammarBlock[]
  dialogueBlocks  DialogueBlock[]
  readingBlocks   ReadingBlock[]
  cultureBlocks   CultureBlock[]
  exercises       Exercise[]

  @@index([lessonId])
}

enum SectionType {
  VOCABULARY
  PHONETICS
  GRAMMAR
  DIALOGUE
  READING
  CULTURE
}

// ==================== КОНТЕНТ УЧЕБНИКА ====================

model VocabularyCard {
  id                 String   @id @default(cuid())
  sectionId          String
  order              Int      @default(0)
  hanzi              String
  pinyin             String
  translation        String
  partOfSpeech       String?
  exampleHanzi       String?
  examplePinyin      String?
  exampleTranslation String?
  audioWordUrl       String?
  audioExampleUrl    String?
  hskLevel           Int?
  tonePattern        Int[]
  strokeCount        Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  section     Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacherNote TeacherNote?

  @@index([sectionId])
}

model ToneBlock {
  id              String   @id @default(cuid())
  sectionId       String
  order           Int      @default(0)
  syllable        String
  tone            Int
  audioUrl        String?
  minimalPairs    Json?
  toneChangeRule  String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model GrammarBlock {
  id                    String   @id @default(cuid())
  sectionId             String
  order                 Int      @default(0)
  title                 String
  formula               String?
  explanationHtml       String?  @db.Text
  examples              Json?
  englishComparisonHtml String?  @db.Text
  commonMistakes        Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  section     Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacherNote TeacherNote?

  @@index([sectionId])
}

model DialogueBlock {
  id             String   @id @default(cuid())
  sectionId      String
  situationTitle String
  speakers       String[]
  lines          Json
  fullAudioUrl   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  section     Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacherNote TeacherNote?

  @@index([sectionId])
}

model ReadingBlock {
  id              String   @id @default(cuid())
  sectionId       String
  textHanziHtml   String   @db.Text
  textPinyinHtml  String?  @db.Text
  translationHtml String?  @db.Text
  questions       Json?
  audioUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

model CultureBlock {
  id          String   @id @default(cuid())
  sectionId   String
  title       String
  contentHtml String   @db.Text
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

// ==================== СЛОЙ УЧИТЕЛЯ ====================

model TeacherNote {
  id                   String   @id @default(cuid())
  vocabularyCardId     String?  @unique
  grammarBlockId       String?  @unique
  dialogueBlockId      String?  @unique
  pronunciationTipHtml String?  @db.Text
  commonErrorsHtml     String?  @db.Text
  mnemonic             String?
  culturalContextHtml  String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  vocabularyCard VocabularyCard? @relation(fields: [vocabularyCardId], references: [id], onDelete: Cascade)
  grammarBlock   GrammarBlock?   @relation(fields: [grammarBlockId], references: [id], onDelete: Cascade)
  dialogueBlock  DialogueBlock?  @relation(fields: [dialogueBlockId], references: [id], onDelete: Cascade)
}

model LessonPlan {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  objectives      String[]
  timing60        Json?
  timing45        Json?
  materialsNeeded String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ==================== УПРАЖНЕНИЯ ====================

model Exercise {
  id                  String       @id @default(cuid())
  sectionId           String
  exerciseType        ExerciseType
  order               Int          @default(0)
  instructionText     String       @db.Text
  difficulty          Int          @default(1)
  contentJson         Json
  gradingType         GradingType  @default(AUTO)
  correctAnswers      String[]
  strictnessConfig    Json?
  referenceAnswer     String?      @db.Text
  gradingCriteria     String?      @db.Text
  isBankExercise      Boolean      @default(false)
  isDefaultInWorkbook Boolean      @default(true)
  isPublished         Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  section  Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers  ExerciseAnswer[]

  @@index([sectionId])
  @@index([exerciseType])
  @@index([isBankExercise])
}

enum ExerciseType {
  MATCHING
  MULTIPLE_CHOICE
  FILL_BLANK
  TONE_PLACEMENT
  TONE_LISTENING
  MINIMAL_PAIRS
  PINYIN_ASSEMBLY
  STROKE_ORDER_DEMO
  CHARACTER_TRACING
  CHARACTER_FROM_MEMORY
  WORD_ORDER
  SENTENCE_TRANSFORM
  GRAMMAR_CHOICE
  LISTEN_AND_CHOOSE
  DIALOGUE_FILL_BLANKS
  DICTATION
  TRANSLATE_TO_CHINESE
  TRANSLATE_TO_ENGLISH
  DESCRIBE_IMAGE
}

enum GradingType {
  AUTO
  TEACHER
}

model ExerciseAnswer {
  id              String        @id @default(cuid())
  exerciseId      String
  studentId       String?
  answersJson     Json
  score           Int?
  status          AnswerStatus  @default(PENDING)
  teacherComment  String?       @db.Text
  gradedBy        String?
  attemptNumber   Int           @default(1)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@index([studentId])
}

enum AnswerStatus {
  PENDING
  GRADED
  AUTO_GRADED
}
