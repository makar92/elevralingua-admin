// ===========================================
// Файл: prisma/schema.prisma
// Путь:  linguamethod-admin/prisma/schema.prisma
//
// Описание:
//   БЛОЧНАЯ АРХИТЕКТУРА v2.
//   Свободные разделы + универсальные блоки-кирпичики.
//   Вместо 6 таблиц контента — одна ContentBlock.
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ПОЛЬЗОВАТЕЛИ ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          UserRole  @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  LINGUIST
}

// ==================== ИЕРАРХИЯ: КУРС > МОДУЛЬ > УРОК > РАЗДЕЛ ====================

model Course {
  id             String   @id @default(cuid())
  title          String
  language       String
  targetLanguage String
  level          String
  description    String?  @db.Text
  coverImageUrl  String?
  isPublished    Boolean  @default(false)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modules Module[]
}

model Module {
  id             String   @id @default(cuid())
  courseId        String
  title          String
  description    String?  @db.Text
  order          Int      @default(0)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id             String   @id @default(cuid())
  moduleId       String
  title          String
  description    String?  @db.Text
  order          Int      @default(0)
  estimatedHours Float    @default(3)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  module     Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sections   Section[]
  lessonPlan LessonPlan?

  @@index([moduleId])
}

// Раздел — СВОБОДНЫЙ. Любое название, любой порядок.
model Section {
  id        String   @id @default(cuid())
  lessonId  String
  title     String   // Свободное: "Новые слова", "О культуре", что угодно
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  blocks    ContentBlock[] // Блоки-кирпичики внутри раздела
  exercises Exercise[]

  @@index([lessonId])
}

// ==================== БЛОКИ КОНТЕНТА (кирпичики) ====================

// Универсальный блок. Один тип таблицы для всего контента.
// Тип блока определяет структуру contentJson.
model ContentBlock {
  id          String           @id @default(cuid())
  sectionId   String
  type        ContentBlockType // Какой это блок (текст, картинка, карточка слова...)
  order       Int              @default(0) // Порядок в разделе (для перемещения)
  contentJson Json             // Содержимое — структура зависит от type
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  section     Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacherNote TeacherNote? // Методическая заметка (только для учителя)

  @@index([sectionId])
}

// 10 типов блоков
enum ContentBlockType {
  // Базовые
  TEXT           // Форматированный текст (Tiptap)
  IMAGE          // Картинка с подписью
  AUDIO          // Аудио-файл с плеером
  YOUTUBE        // Видео с YouTube
  DIVIDER        // Разделитель (горизонтальная линия)
  HTML_EMBED     // Кастомный HTML/iframe код

  // Специализированные для языков
  VOCAB_CARD     // Карточка слова (иероглиф + пиньинь + перевод + аудио + пример)
  GRAMMAR_RULE   // Грамматическое правило (формула + объяснение + примеры)
  DIALOGUE       // Диалог (участники + реплики + аудио)
  TONE_BLOCK     // Тоновый блок (слог + тон + аудио + минимальные пары)
}

// ==================== СЛОЙ УЧИТЕЛЯ ====================

// Методическая заметка — привязывается к ЛЮБОМУ блоку
model TeacherNote {
  id             String   @id @default(cuid())
  contentBlockId String   @unique
  noteHtml       String   @db.Text // Текст заметки
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contentBlock ContentBlock @relation(fields: [contentBlockId], references: [id], onDelete: Cascade)
}

// План урока
model LessonPlan {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  objectives      String[]
  timing60        Json?
  timing45        Json?
  materialsNeeded String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ==================== УПРАЖНЕНИЯ (ТЕТРАДЬ + БАНК) ====================

model Exercise {
  id                  String       @id @default(cuid())
  sectionId           String
  exerciseType        ExerciseType
  order               Int          @default(0)
  instructionText     String       @db.Text
  difficulty          Int          @default(1)
  contentJson         Json
  gradingType         GradingType  @default(AUTO)
  correctAnswers      String[]
  strictnessConfig    Json?
  referenceAnswer     String?      @db.Text
  gradingCriteria     String?      @db.Text
  isBankExercise      Boolean      @default(false)
  isDefaultInWorkbook Boolean      @default(true)
  isPublished         Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  section  Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers  ExerciseAnswer[]

  @@index([sectionId])
  @@index([exerciseType])
}

enum ExerciseType {
  MATCHING
  MULTIPLE_CHOICE
  FILL_BLANK
  TONE_PLACEMENT
  TONE_LISTENING
  MINIMAL_PAIRS
  PINYIN_ASSEMBLY
  STROKE_ORDER_DEMO
  CHARACTER_TRACING
  CHARACTER_FROM_MEMORY
  WORD_ORDER
  SENTENCE_TRANSFORM
  GRAMMAR_CHOICE
  LISTEN_AND_CHOOSE
  DIALOGUE_FILL_BLANKS
  DICTATION
  TRANSLATE_TO_CHINESE
  TRANSLATE_TO_ENGLISH
  DESCRIBE_IMAGE
}

enum GradingType {
  AUTO
  TEACHER
}

model ExerciseAnswer {
  id              String        @id @default(cuid())
  exerciseId      String
  studentId       String?
  answersJson     Json
  score           Int?
  status          AnswerStatus  @default(PENDING)
  teacherComment  String?       @db.Text
  gradedBy        String?
  attemptNumber   Int           @default(1)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
}

enum AnswerStatus {
  PENDING
  GRADED
  AUTO_GRADED
}
